#--------------------------------------------------------------------
# ENVIRONMENT
#--------------------------------------------------------------------
# Set to 'production' for production server
CI_ENVIRONMENT = development

#--------------------------------------------------------------------
# APP
#--------------------------------------------------------------------
app.baseURL = 'http://localhost:8080/'
# app.forceGlobalSecureRequests = true

#--------------------------------------------------------------------
# DATABASE (used by both CI4 and docker-compose)
#--------------------------------------------------------------------
database.default.hostname = db
database.default.database = hmsi_niskalarasi
database.default.username = YOUR_DB_USER
database.default.password = YOUR_STRONG_PASSWORD_HERE
database.default.DBDriver = MySQLi
database.default.DBPrefix =
database.default.port = 3306
database.default.charset = utf8mb4
database.default.DBCollat = utf8mb4_general_ci

# Docker MySQL container credentials (MUST match database.default values)
DB_ROOT_PASSWORD = YOUR_ROOT_PASSWORD_HERE
DB_DATABASE = hmsi_niskalarasi
DB_USERNAME = YOUR_DB_USER
DB_PASSWORD = YOUR_STRONG_PASSWORD_HERE

#--------------------------------------------------------------------
# SESSION (Redis)
#--------------------------------------------------------------------
app.sessionDriver = 'CodeIgniter\Session\Handlers\RedisHandler'
app.sessionSavePath = 'tcp://redis:6379'
app.sessionCookieName = ci_session
app.sessionExpiration = 7200

#--------------------------------------------------------------------
# ENCRYPTION
#--------------------------------------------------------------------
# encryption.key = hex2bin:YOUR_HEX_KEY_HERE
